{
  "routes": [
    {
      "route": "/assets/*",
      "serve": "/assets/*"
    },
    {
      "route": "/*.svg",
      "serve": "/*.svg"
    },
    {
      "route": "/*.png",
      "serve": "/*.png"
    },
    {
      "route": "/api/*",
      "serve": "/api/*"
    },
    {
      "route": "/*",
      "rewrite": "/index.html"
    }
  ]
}
